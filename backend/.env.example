# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster_host>/clinic_management?retryWrites=true&w=majority

# Security Keys
JWT_SECRET=your_jwt_secret_key_here

# Client/Frontend URLs (Comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173,https://your-production-app.vercel.app

# Third-Party API integrations
STRIPE_SECRET_KEY=your_stripe_secret_key_here
GEMINI_API_KEY=your_gemini_api_key_here
